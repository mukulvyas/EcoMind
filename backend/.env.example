GEMINI_API_KEY=your_gemini_api_key_here
DATA_GOV_API_KEY=your_data_gov_api_key_here
FRONTEND_URL=https://your-frontend-url.run.app
# Full JSON string of your Firebase service account key (required for Firestore on Cloud Run)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON content as a single-line string (use jq: jq -c . key.json)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}